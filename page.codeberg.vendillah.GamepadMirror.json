{
    "id" : "page.codeberg.vendillah.GamepadMirror",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.node20",
        "org.freedesktop.Sdk.Extension.typescript"
    ],
    "command" : "page.codeberg.vendillah.GamepadMirror",
    "finish-args" : [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--device=all"
    ],
    "build-options" : {
        "append-path" : "/usr/lib/sdk/typescript/bin:/usr/lib/sdk/node20/bin"
    },
    "modules" : [
        {
            "name" : "gamepad-mirror",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://codeberg.org/vendillah/GamepadMirror.git",
                    "commit": "aa86d55f21b4d206eab61d0bf7cd9ccafc8aa607"
                }
            ]
        }
    ]
}
